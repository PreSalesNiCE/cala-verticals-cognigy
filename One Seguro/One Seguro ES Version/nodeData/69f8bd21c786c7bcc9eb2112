iente.\"\n    },\n    \"local_sinistro\": {\n      \"type\": \"string\",\n      \"description\": \"O local onde o sinistro aconteceu. \"\n    },\n    \"tipo_sinistro\": {\n      \"type\": \"string\",\n      \"description\": \"A categoria de sinistro que o cliente está reportando. O tipo de evento poderá ser colisão, furto ou bateria. \"\n    }\n  },\n  \"required\": [\n    \"veiculo\",\n    \"data_sinistro\",\n    \"local_sinistro\",\n    \"tipo_sinistro\"\n  ],\n  \"additionalProperties\": false\n}","debugMessage":true,"condition":""},"preview":"avaliar_sinistro","localeReference":"69f8bd21c786c7bcc9eb20fd"}],"chartReference":"69f8bd21c786c7bcc9eb2101","resourceReference":"69f8bd21c786c7bcc9eb2100","projectReference":"69f8bd21c786c7bcc9eb20b3","organisationReference":"68bdfe9b0d262300236aafc7"}