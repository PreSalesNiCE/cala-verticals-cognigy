{"_id":"69f8bd21c786c7bcc9eb215c","referenceId":"6f70e0eb-5e7e-4400-aed3-faf8561378e3","type":"setHTMLAppState","extension":"@cognigy/basic-nodes","label":"Detalles del incidente - Page","comment":"","commentColor":"","analyticsLabel":null,"isEntryPoint":true,"isDisabled":false,"mock":{"isEnabled":false,"code":""},"localizedData":[{"config":{"mode":"full","html":"<!DOCTYPE html>\n<html lang=\"es\">\n\n<head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>One Seguros - Detalles del Evento</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script>\n        tailwind.config = {\n            theme: {\n                extend: {\n                    colors: {\n                        onePrimary: '#1E3A8A',\n                        onePrimaryLight: '#E5F0FF',\n                        oneDark: '#111827',\n                        oneLight: '#F9FAFB',\n                        oneGold: '#D4AF37'\n                    }\n                }\n            }\n        }\n    </script>\n    <script src=\"/sdk/app-page-sdk.js\"></script>\n</head>\n\n<body class=\"min-h-screen bg-oneLight text-oneDark\">\n    <div class=\"max-w-3xl mx-auto px-4 py-6\">\n        <!-- Header -->\n        <header class=\"flex items-center justify-between mb-4\">\n            <div class=\"flex items-center gap-2\">\n                <button type=\"button\" onclick=\"handleBack()\"\n                    class=\"mr-2 inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs text-slate-600 hover:border-onePrimary hover:text-onePrimary hover:bg-onePrimaryLight transition\">\n                    ← Atrás\n                </button>\n                <div class=\"flex items-center gap-2\">\n                    <div class=\"w-9 h-9 rounded-full bg-onePrimary flex items-center justify-center\">\n                        <span class=\"text-white text-sm font-semibold\">1S</span>\n                    </div>\n                    <div>\n                        <h1 class=\"text-lg font-semibold text-oneDark\">Detalles del evento</h1>\n                        <p class=\"text-xs text-slate-500\">Cuéntanos rápidamente qué pasó.</p>\n                    </div>\n                </div>\n            </div>\n            <span class=\"text-xs text-slate-500\">Paso 2 de 6</span>\n        </header>\n\n        <main class=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-5 space-y-5\">\n            <!-- Barra de progreso -->\n            <section>\n                <div class=\"flex items-center justify-between text-xs mb-1\">\n                    <span class=\"font-medium text-oneDark\">Progreso</span>\n                    <span class=\"text-slate-500\">Detalles del evento</span>\n                </div>\n                <div class=\"w-full bg-slate-100 rounded-full h-1.5 overflow-hidden\">\n                    <div class=\"h-1.5 w-2/6 bg-gradient-to-r from-oneGold to-onePrimary rounded-full\"></div>\n                </div>\n            </section>\n\n            <form id=\"detailsForm\" class=\"space-y-4\" onsubmit=\"handleSubmit(event)\">\n                <!-- Fecha y hora -->\n                <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n                    <div>\n                        <label class=\"block text-xs font-medium text-slate-600 mb-1\">\n                            Fecha del evento\n                        </label>\n                        <input type=\"date\" id=\"date\" required\n                            class=\"w-full rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-onePrimary focus:border-onePrimary\" />\n                    </div>\n                    <div>\n                        <label class=\"block text-xs font-medium text-slate-600 mb-1\">\n                            Hora aproximada\n                        </label>\n                        <div class=\"flex gap-2\">\n                            <input type=\"time\" id=\"time\" required\n                                class=\"flex-1 rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-onePrimary focus:border-onePrimary\" />\n                            <button type=\"button\" onclick=\"setNow()\"\n                                class=\"px-3 py-2 text-xs rounded-lg border border-onePrimary text-onePrimary bg-onePrimaryLight hover:bg-onePrimary hover:text-white transition\">\n                                Ahora\n                            </button>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Situación actual -->\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-2\">\n                        Situación actual del vehículo\n                    </label>\n                    <div class=\"grid grid-cols-1 sm:grid-cols-3 gap-2 text-sm\">\n                        <button type=\"button\" data-value=\"normal\"\n                            class=\"vehicle-status-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-left hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            onclick=\"selectStatus(this)\">\n                            Puede circular normalmente\n                        </button>\n                        <button type=\"button\" data-value=\"danificado_anda\"\n                            class=\"vehicle-status-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-left hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            onclick=\"selectStatus(this)\">\n                            Dañado, pero aún circula\n                        </button>\n                        <button type=\"button\" data-value=\"imobilizado\"\n                            class=\"vehicle-status-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-left hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            onclick=\"selectStatus(this)\">\n                            Inmovilizado / necesita grúa\n                        </button>\n                    </div>\n                    <input type=\"hidden\" id=\"vehicleStatus\" required />\n                </div>\n\n                <!-- Heridos -->\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-2\">\n                        ¿Hubo heridos?\n                    </label>\n                    <div class=\"flex flex-wrap gap-2 text-sm\">\n                        <button type=\"button\" data-value=\"nao\"\n                            class=\"injury-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            onclick=\"selectInjury(this)\">\n                            No\n                        </button>\n                        <button type=\"button\" data-value=\"leves\"\n                            class=\"injury-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            onclick=\"selectInjury(this)\">\n                            Sí, leves\n                        </button>\n                        <button type=\"button\" data-value=\"graves\"\n                            class=\"injury-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            onclick=\"selectInjury(this)\">\n                            Sí, graves / SAMU llamado\n                        </button>\n                    </div>\n                    <input type=\"hidden\" id=\"injuryStatus\" required />\n                </div>\n\n                <!-- Descripción -->\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-1\">\n                        Describe rápidamente qué pasó\n                    </label>\n                    <textarea id=\"description\" rows=\"4\"\n                        placeholder=\"Ej.: Estaba parado en el semáforo y el carro de atrás chocó contra mi parte trasera.\"\n                        class=\"w-full rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-onePrimary focus:border-onePrimary resize-y\"></textarea>\n                    <p class=\"mt-1 text-xs text-slate-500\">\n                        No te preocupes por detalles legales. Después un especialista de One Seguros hablará contigo.\n                    </p>\n                </div>\n\n                <!-- Rodapé -->\n                <div class=\"pt-3 border-t border-slate-100 flex items-center justify-between\">\n                    <p class=\"text-xs text-slate-500\">\n                        Próximo paso: vamos a marcar el lugar del siniestro en el mapa.\n                    </p>\n                    <button type=\"submit\"\n                        class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-oneGold to-onePrimary text-white text-sm font-medium shadow-sm hover:opacity-95 transition\">\n                        Continuar\n                        <span>→</span>\n                    </button>\n                </div>\n            </form>\n        </main>\n    </div>\n\n    <script>\n        function handleBack() {\n            SDK.submit({\n                step: 'voltar',\n                toPage: 'inicio' // personaliza para cada página\n            });\n        }\n\n        function setNow() {\n            const now = new Date();\n            const dateInput = document.getElementById('date');\n            const timeInput = document.getElementById('time');\n\n            const yyyy = now.getFullYear();\n            const mm = String(now.getMonth() + 1).padStart(2, '0');\n            const dd = String(now.getDate()).padStart(2, '0');\n            const hh = String(now.getHours()).padStart(2, '0');\n            const mi = String(now.getMinutes()).padStart(2, '0');\n\n            dateInput.value = `${yyyy}-${mm}-${dd}`;\n            timeInput.value = `${hh}:${mi}`;\n        }\n\n        function selectStatus(btn) {\n            document.querySelectorAll('.vehicle-status-btn').forEach(b => {\n                b.classList.remove('border-onePrimary', 'bg-onePrimaryLight');\n            });\n            btn.classList.add('border-onePrimary', 'bg-onePrimaryLight');\n            document.getElementById('vehicleStatus').value = btn.dataset.value;\n        }\n\n        function selectInjury(btn) {\n            document.querySelectorAll('.injury-btn').forEach(b => {\n                b.classList.remove('border-onePrimary', 'bg-onePrimaryLight');\n            });\n            btn.classList.add('border-onePrimary', 'bg-onePrimaryLight');\n            document.getElementById('injuryStatus').value = btn.dataset.value;\n        }\n\n        function handleSubmit(event) {\n            event.preventDefault();\n            const payload = {\n                step: 'detalhesEvento',\n                date: document.getElementById('date').value,\n                time: document.getElementById('time').value,\n                vehicleStatus: document.getElementById('vehicleStatus').value,\n                injuryStatus: document.getElementById('injuryStatus').value,\n                description: document.getElementById('description').value\n            };\n            SDK.submit(payload);\n        }\n    </script>\n</body>\n\n</html>","body":"<form>\n\t<input \n\t\tname=\"nickname\" \n\t\tplaceholder=\"your nickname\"\n\t/> \n\t<button>submit</button>\n</form>\n","waitForInput":false,"storeResultInContext":"","contextKey":"result","screenTitle":"","showCloseIcon":true,"sendEventOnCloseIconClick":false,"autoOpen":true,"closeOnSubmit":true,"feedbackMessage":""},"preview":"","localeReference":"69f8bd21c786c7bcc9eb20fd"}],"chartReference":"69f8bd21c786c7bcc9eb2101","resourceReference":"69f8bd21c786c7bcc9eb2100","projectReference":"69f8bd21c786c7bcc9eb20b3","organisationReference":"68bdfe9b0d262300236aafc7"}