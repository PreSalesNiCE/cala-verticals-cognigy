{"_id":"69f8abdb1d175af3ed2a8d96","referenceId":"67f4d7aa-3744-4904-9117-699cd0297303","type":"setHTMLAppState","label":"Local Sinistro","comment":"","commentColor":"","analyticsLabel":null,"isDisabled":false,"isEntryPoint":true,"localizedData":[{"config":{"mode":"full","html":"<!DOCTYPE html>\n<html lang=\"pt-BR\">\n\n<head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>One Seguros - Local do Sinistro</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script>\n        tailwind.config = {\n            theme: {\n                extend: {\n                    colors: {\n                        onePrimary: '#1E3A8A',\n                        onePrimaryLight: '#E5F0FF',\n                        oneDark: '#111827',\n                        oneLight: '#F9FAFB',\n                        oneGold: '#D4AF37'\n                    }\n                }\n            }\n        }\n    </script>\n\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.css\"\n        integrity=\"sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=\" crossorigin=\"\" />\n    <script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"\n        integrity=\"sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=\" crossorigin=\"\"></script>\n\n    <script src=\"/sdk/app-page-sdk.js\"></script>\n</head>\n\n<body class=\"min-h-screen bg-oneLight text-oneDark\">\n    <div class=\"max-w-3xl mx-auto px-4 py-6\">\n        <!-- Header -->\n        <header class=\"flex items-center justify-between mb-4\">\n            <div class=\"flex items-center gap-2\">\n                <button type=\"button\" onclick=\"handleBack()\"\n                    class=\"mr-2 inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs text-slate-600 hover:border-onePrimary hover:text-onePrimary hover:bg-onePrimaryLight transition\">\n                    ← Voltar\n                </button>\n                <div class=\"flex items-center gap-2\">\n                    <div class=\"w-9 h-9 rounded-full bg-onePrimary flex items-center justify-center\">\n                        <span class=\"text-white text-sm font-semibold\">1S</span>\n                    </div>\n                    <div>\n                        <h1 class=\"text-lg font-semibold text-oneDark\">Detalhes do evento</h1>\n                        <p class=\"text-xs text-slate-500\">Conte rapidamente o que aconteceu.</p>\n                    </div>\n                </div>\n            </div>\n            <span class=\"text-xs text-slate-500\">Passo 2 de 6</span>\n        </header>\n\n        <main class=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-4 space-y-4\">\n            <!-- Progresso -->\n            <section>\n                <div class=\"flex items-center justify-between text-xs mb-1\">\n                    <span class=\"font-medium text-oneDark\">Progresso</span>\n                    <span class=\"text-slate-500\">Local do sinistro</span>\n                </div>\n                <div class=\"w-full bg-slate-100 rounded-full h-1.5 overflow-hidden\">\n                    <div class=\"h-1.5 w-3/6 bg-gradient-to-r from-oneGold to-onePrimary rounded-full\"></div>\n                </div>\n            </section>\n\n            <!-- Busca + legenda -->\n            <section class=\"space-y-2\">\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-1\">\n                        Busque o endereço ou toque no mapa\n                    </label>\n                    <div class=\"flex gap-2\">\n                        <input type=\"text\" id=\"addressInput\" placeholder=\"Ex.: Av. Paulista, 1000 - São Paulo\"\n                            class=\"flex-1 rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-onePrimary focus:border-onePrimary\" />\n                        <button type=\"button\" onclick=\"searchAddress()\"\n                            class=\"px-3 py-2 text-xs rounded-lg bg-onePrimary text-white font-medium hover:opacity-95\">\n                            Buscar\n                        </button>\n                    </div>\n                    <p class=\"mt-1 text-xs text-slate-500\">\n                        Se o sinistro não aconteceu onde você está agora, toque no mapa ou digite o endereço.\n                    </p>\n                </div>\n\n                <div class=\"flex items-center gap-3 text-xs text-slate-500\">\n                    <div class=\"flex items-center gap-1\">\n                        <span class=\"inline-block w-2.5 h-2.5 rounded-full bg-blue-500\"></span>\n                        <span>Você está aqui</span>\n                    </div>\n                    <div class=\"flex items-center gap-1\">\n                        <span class=\"inline-block w-2.5 h-2.5 rounded-full bg-red-500\"></span>\n                        <span>Local do sinistro</span>\n                    </div>\n                </div>\n            </section>\n\n            <!-- Mapa -->\n            <section>\n                <div id=\"map\" class=\"w-full h-72 rounded-xl overflow-hidden border border-slate-200\"></div>\n            </section>\n\n            <!-- Endereço selecionado + botão -->\n            <section\n                class=\"pt-2 border-t border-slate-100 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between\">\n                <div class=\"text-xs\">\n                    <p class=\"font-medium text-oneDark mb-1\">Endereço selecionado</p>\n                    <p id=\"selectedAddress\" class=\"text-slate-500\">\n                        Nenhum local selecionado ainda.\n                    </p>\n                </div>\n                <button id=\"confirmBtn\" type=\"button\" onclick=\"submitLocation()\" disabled\n                    class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-oneGold to-onePrimary text-white text-sm font-medium shadow-sm disabled:opacity-40 disabled:cursor-not-allowed hover:opacity-95 transition\">\n                    Confirmar local\n                    <span>→</span>\n                </button>\n            </section>\n        </main>\n    </div>\n\n    <script>\n        let map;\n        let userMarker;\n        let claimMarker;\n        let selectedLocation = null;\n\n        function handleBack() {\n            SDK.submit({\n                step: 'voltar',\n                toPage: 'detalhes' // personalize para cada página\n            });\n        }\n\n        function initMap() {\n            map = L.map('map').setView([-23.55052, -46.633308], 13);\n\n            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {\n                attribution: '&copy; OpenStreetMap contributors'\n            }).addTo(map);\n\n            // Localização atual\n            if (navigator.geolocation) {\n                navigator.geolocation.getCurrentPosition(\n                    (position) => {\n                        const lat = position.coords.latitude;\n                        const lng = position.coords.longitude;\n                        const userLatLng = [lat, lng];\n\n                        userMarker = L.circleMarker(userLatLng, {\n                            radius: 7,\n                            color: '#2563EB',\n                            fillColor: '#3B82F6',\n                            fillOpacity: 0.9\n                        }).addTo(map);\n\n                        userMarker.bindPopup('Você está aqui').openPopup();\n                        map.setView(userLatLng, 15);\n                    },\n                    () => {\n                        // Se negar GPS, mantemos centro padrão\n                    }\n                );\n            }\n\n            // Clique no mapa\n            map.on('click', (e) => {\n                const { lat, lng } = e.latlng;\n                setClaimMarker(lat, lng);\n                reverseGeocode(lat, lng);\n            });\n        }\n\n        function setClaimMarker(lat, lng) {\n            if (claimMarker) {\n                map.removeLayer(claimMarker);\n            }\n            claimMarker = L.marker([lat, lng], {\n                draggable: true\n            }).addTo(map);\n\n            claimMarker.on('dragend', (e) => {\n                const { lat, lng } = e.target.getLatLng();\n                reverseGeocode(lat, lng);\n            });\n\n            selectedLocation = { lat, lng };\n        }\n\n        async function reverseGeocode(lat, lng) {\n            try {\n                const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&addressdetails=1&accept-language=pt-BR`;\n                const res = await fetch(url, {\n                    headers: {\n                        'User-Agent': 'OneSegurosSinistro/1.0'\n                    }\n                });\n                const data = await res.json();\n                const addr = data.address || {};\n                const parts = [\n                    addr.road,\n                    addr.house_number,\n                    addr.suburb || addr.neighbourhood,\n                    addr.city || addr.town || addr.village,\n                    addr.state\n                ].filter(Boolean);\n\n                const addressText = parts.join(', ');\n                document.getElementById('selectedAddress').textContent =\n                    addressText || 'Endereço aproximado selecionado.';\n                document.getElementById('confirmBtn').disabled = false;\n\n                selectedLocation = {\n                    ...selectedLocation,\n                    address: addressText || data.display_name\n                };\n            } catch (e) {\n                document.getElementById('selectedAddress').textContent =\n                    'Local selecionado, mas não foi possível obter o endereço. Você pode detalhar depois.';\n                document.getElementById('confirmBtn').disabled = false;\n            }\n        }\n\n        async function searchAddress() {\n            const q = document.getElementById('addressInput').value.trim();\n            if (!q) return;\n\n            const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(\n                q\n            )}&addressdetails=1&limit=1&accept-language=pt-BR`;\n\n            try {\n                const res = await fetch(url, {\n                    headers: {\n                        'User-Agent': 'OneSegurosSinistro/1.0'\n                    }\n                });\n                const data = await res.json();\n                if (!data.length) return;\n                const item = data[0];\n                const lat = parseFloat(item.lat);\n                const lng = parseFloat(item.lon);\n\n                map.setView([lat, lng], 16);\n                setClaimMarker(lat, lng);\n                reverseGeocode(lat, lng);\n            } catch (e) {\n                // silencioso\n            }\n        }\n\n        function submitLocation() {\n            if (!selectedLocation) return;\n            SDK.submit({\n                step: 'localSinistro',\n                latitude: selectedLocation.lat,\n                longitude: selectedLocation.lng,\n                address: selectedLocation.address\n            });\n        }\n\n        document.addEventListener('DOMContentLoaded', initMap);\n    </script>\n</body>\n\n</html>","body":"<form>\n\t<input \n\t\tname=\"nickname\" \n\t\tplaceholder=\"your nickname\"\n\t/> \n\t<button>submit</button>\n</form>\n","waitForInput":false,"storeResultInContext":"","contextKey":"result","screenTitle":"","showCloseIcon":true,"sendEventOnCloseIconClick":false,"autoOpen":true,"closeOnSubmit":true,"feedbackMessage":""},"preview":"","localeReference":"69f8abdb1d175af3ed2a8d25"}],"chartReference":"69f8abdb1d175af3ed2a8d29","extension":"@cognigy/basic-nodes","resourceReference":"69f8abdb1d175af3ed2a8d28","projectReference":"69f8abdb1d175af3ed2a8cc7","organisationReference":"68bdfe9b0d262300236aafc7","mock":{"isEnabled":false,"code":""}}