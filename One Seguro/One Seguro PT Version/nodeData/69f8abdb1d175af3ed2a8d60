{"_id":"69f8abdb1d175af3ed2a8d60","referenceId":"37e986b9-67a5-4100-b5a9-4d143fd5baac","type":"setHTMLAppState","extension":"@cognigy/basic-nodes","label":"xApp: Show HTML","comment":"","commentColor":"","analyticsLabel":null,"isEntryPoint":false,"isDisabled":false,"mock":{"isEnabled":false,"code":""},"localizedData":[{"config":{"mode":"full","html":"<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Agendamento - One Seguros</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"/sdk/app-page-sdk.js\"></script>\n</head>\n<body class=\"bg-gradient-to-br from-slate-50 to-blue-50 min-h-screen py-12 px-4 sm:px-6 lg:px-8\">\n  <div class=\"max-w-md mx-auto bg-white rounded-3xl shadow-2xl border border-slate-200 p-8 space-y-8\">\n    \n    <!-- Header -->\n    <div class=\"text-center space-y-4\">\n      <div class=\"w-20 h-20 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-2xl mx-auto shadow-xl flex items-center justify-center\">\n        <svg class=\"w-10 h-10 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"/>\n        </svg>\n      </div>\n      <div>\n        <h1 class=\"text-3xl font-bold bg-gradient-to-r from-gray-900 to-slate-700 bg-clip-text text-transparent\">One Seguros</h1>\n        <p class=\"text-lg text-slate-600 font-medium mt-1\">Agende seu atendimento</p>\n      </div>\n    </div>\n\n    <!-- Calendário -->\n    <div class=\"space-y-6\">\n      <!-- Navegação -->\n      <div class=\"flex items-center justify-between\">\n        <button id=\"prevBtn\" class=\"p-3 rounded-xl hover:bg-slate-100 transition-all duration-200 flex items-center justify-center w-12 h-12 shadow-sm hover:shadow-md\">\n          <svg class=\"w-6 h-6 text-slate-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"/>\n          </svg>\n        </button>\n        <h2 id=\"monthTitle\" class=\"text-2xl font-bold text-slate-900\"></h2>\n        <button id=\"nextBtn\" class=\"p-3 rounded-xl hover:bg-slate-100 transition-all duration-200 flex items-center justify-center w-12 h-12 shadow-sm hover:shadow-md\">\n          <svg class=\"w-6 h-6 text-slate-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"/>\n          </svg>\n        </button>\n      </div>\n\n      <!-- Dias da semana -->\n      <div class=\"grid grid-cols-7 gap-2 text-center\">\n        <div class=\"px-3 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide\">Dom</div>\n        <div class=\"px-3 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide\">Seg</div>\n        <div class=\"px-3 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide\">Ter</div>\n        <div class=\"px-3 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide\">Qua</div>\n        <div class=\"px-3 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide\">Qui</div>\n        <div class=\"px-3 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide\">Sex</div>\n        <div class=\"px-3 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide\">Sáb</div>\n      </div>\n\n      <!-- Dias do mês -->\n      <div id=\"calendarGrid\" class=\"grid grid-cols-7 gap-2\"></div>\n    </div>\n\n    <!-- Horários -->\n    <div id=\"timePicker\" class=\"hidden space-y-4\">\n      <div class=\"text-center\">\n        <h3 class=\"text-xl font-bold text-slate-900 mb-2\">Horários disponíveis</h3>\n        <p id=\"selectedDateDisplay\" class=\"text-slate-600 font-medium\"></p>\n      </div>\n      <div id=\"timeButtons\" class=\"grid grid-cols-2 gap-3 max-h-64 overflow-y-auto scrollbar-thin scrollbar-thumb-slate-300 scrollbar-track-slate-100 p-2\"></div>\n    </div>\n\n    <!-- Confirmação -->\n    <div id=\"confirmSection\" class=\"hidden space-y-4 pt-4\">\n      <div class=\"bg-green-50 border-2 border-green-200 rounded-2xl p-6 text-center\">\n        <svg class=\"w-12 h-12 text-green-500 mx-auto mb-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"/>\n        </svg>\n        <p id=\"finalDisplay\" class=\"text-xl font-bold text-green-800\"></p>\n      </div>\n      <button id=\"confirmButton\" class=\"w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-4 px-6 rounded-2xl font-semibold text-lg shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed disabled:scale-100 flex items-center justify-center gap-2 mx-auto\">\n        <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"/>\n        </svg>\n        Confirmar Agendamento\n      </button>\n    </div>\n  </div>\n\n  <script>\n    const horariosDisponiveis = [\"09:00\", \"10:00\", \"11:00\", \"13:00\", \"14:00\", \"15:00\", \"16:00\"];\n    \n    const hoje = new Date();\n    hoje.setHours(0, 0, 0, 0);\n    \n    let view = new Date();\n    let dataSelecionada = null;\n    let horarioSelecionado = null;\n\n    function renderCalendar() {\n      const y = view.getFullYear();\n      const m = view.getMonth();\n      \n      document.getElementById('monthTitle').textContent = \n        view.toLocaleString('pt-BR', { month: 'long', year: 'numeric' });\n\n      const first = new Date(y, m, 1);\n      const start = first.getDay();\n      const days = new Date(y, m + 1, 0).getDate();\n      \n      let html = '';\n      \n      // Espaços vazios\n      for (let i = 0; i < (start === 0 ? 6 : start - 1); i++) {\n        html += '<div class=\"w-14 h-14\"></div>';\n      }\n      \n      // Dias\n      for (let d = 1; d <= days; d++) {\n        const iso = `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;\n        const dataAtual = new Date(iso);\n        \n        let classes = 'w-14 h-14 rounded-xl font-semibold text-sm transition-all duration-200 flex items-center justify-center shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2';\n        \n        if (dataAtual < hoje) {\n          classes += ' bg-slate-50 text-slate-400 cursor-not-allowed';\n        } else if (dataSelecionada === iso) {\n          classes += ' bg-blue-500 text-white shadow-lg hover:shadow-xl scale-105';\n        } else if (dataAtual.toDateString() === hoje.toDateString()) {\n          classes += ' bg-green-500 text-white shadow-lg font-bold';\n        } else {\n          classes += ' bg-white border border-slate-200 hover:bg-blue-50 hover:border-blue-300 hover:scale-105 active:scale-95';\n        }\n        \n        html += `<button class=\"＄{classes}\" data-date=\"${iso}\">${d}</button>`;\n      }\n      \n      document.getElementById('calendarGrid').innerHTML = html;\n      \n      // Listeners dias\n      document.querySelectorAll('#calendarGrid button:not([disabled])').forEach(btn => {\n        btn.addEventListener('click', function() {\n          document.querySelectorAll('#calendarGrid button').forEach(b => {\n            b.classList.remove('bg-blue-500', 'text-white', 'shadow-lg', 'scale-105');\n            if (!b.classList.contains('bg-green-500')) {\n              b.classList.add('bg-white', 'border', 'border-slate-200');\n            }\n          });\n          \n          this.classList.remove('bg-white', 'border', 'border-slate-200', 'hover:bg-blue-50');\n          this.classList.add('bg-blue-500', 'text-white', 'shadow-lg', 'scale-105');\n          \n          dataSelecionada = this.dataset.date;\n          horarioSelecionado = null;\n          renderHorarios();\n        });\n      });\n    }\n\n    function renderHorarios() {\n      const timePicker = document.getElementById('timePicker');\n      const timeButtons = document.getElementById('timeButtons');\n      \n      if (!dataSelecionada) {\n        timePicker.classList.add('hidden');\n        document.getElementById('confirmSection').classList.add('hidden');\n        return;\n      }\n      \n      timePicker.classList.remove('hidden');\n      document.getElementById('selectedDateDisplay').textContent = \n        new Date(dataSelecionada).toLocaleDateString('pt-BR', {\n          weekday: 'long',\n          year: 'numeric',\n          month: 'long',\n          day: 'numeric'\n        });\n      \n      let html = '';\n      horariosDisponiveis.forEach(h => {\n        const isSelected = horarioSelecionado === h;\n        let classes = 'p-4 rounded-xl font-semibold text-lg shadow-sm hover:shadow-lg hover:scale-105 active:scale-95 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2';\n        if (isSelected) {\n          classes += ' bg-blue-500 text-white shadow-xl scale-105';\n        } else {\n          classes += ' bg-white border-2 border-slate-200 hover:border-blue-300 hover:bg-blue-50';\n        }\n        html += `<button class=\"${classes}\" data-time=\"${h}\">${h}</button>`;\n      });\n      \n      timeButtons.innerHTML = html;\n      \n      // Listeners horários\n      timeButtons.querySelectorAll('button').forEach(btn => {\n        btn.addEventListener('click', function() {\n          timeButtons.querySelectorAll('button').forEach(b => {\n            b.classList.remove('bg-blue-500', 'text-white', 'shadow-xl', 'scale-105');\n            b.classList.add('bg-white', 'border-2', 'border-slate-200');\n          });\n          \n          this.classList.remove('bg-white', 'border-2', 'border-slate-200');\n          this.classList.add('bg-blue-500', 'text-white', 'shadow-xl', 'scale-105');\n          \n          horarioSelecionado = this.dataset.time;\n          updateConfirm();\n        });\n      });\n      \n      updateConfirm();\n    }\n\n    function updateConfirm() {\n      const confirmSection = document.getElementById('confirmSection');\n      if (dataSelecionada && horarioSelecionado) {\n        confirmSection.classList.remove('hidden');\n        document.getElementById('finalDisplay').textContent = \n          `${new Date(dataSelecionada).toLocaleDateString('pt-BR')} às ${horarioSelecionado}`;\n        document.getElementById('confirmButton').disabled = false;\n      } else {\n        confirmSection.classList.add('hidden');\n        document.getElementById('confirmButton').disabled = true;\n      }\n    }\n\n    // Navegação\n    document.getElementById('prevBtn').onclick = () => {\n      view.setMonth(view.getMonth() - 1);\n      renderCalendar();\n      dataSelecionada = null;\n      horarioSelecionado = null;\n      document.getElementById('timePicker').classList.add('hidden');\n      document.getElementById('confirmSection').classList.add('hidden');\n    };\n    \n    document.getElementById('nextBtn').onclick = () => {\n      view.setMonth(view.getMonth() + 1);\n      renderCalendar();\n      dataSelecionada = null;\n      horarioSelecionado = null;\n      document.getElementById('timePicker').classList.add('hidden');\n      document.getElementById('confirmSection').classList.add('hidden');\n    };\n\n    // Confirmar - EXATAMENTE como seu script\n    document.getElementById('confirmButton').onclick = async () => {\n      if (!dataSelecionada || !horarioSelecionado) {\n        alert(\"Selecione uma data e horário\");\n        return;\n      }\n      \n      await SDK.submit({\n        data: dataSelecionada,\n        horario: horarioSelecionado\n      });\n    };\n\n    // Inicializar\n    renderCalendar();\n  </script>\n</body>\n</html>","body":"<!DOCTYPE html>\n<html lang=\"pt-br\">\n<head>\n<meta charset=\"UTF-8\">\n\n<style>\n\nbody{\nfont-family: Arial, sans-serif;\nbackground:#f4f6fb;\ndisplay:flex;\njustify-content:center;\nalign-items:center;\nheight:100vh;\nmargin:0;\n}\n\n.container{\nbackground:white;\nwidth:360px;\nborder-radius:14px;\npadding:20px;\nbox-shadow:0 6px 18px rgba(0,0,0,0.15);\n}\n\n.header{\ncolor:#003a8f;\nfont-size:20px;\nfont-weight:bold;\nmargin-bottom:12px;\n}\n\n.calendar{\ndisplay:grid;\ngrid-template-columns: repeat(7,1fr);\ngap:6px;\nmargin-bottom:14px;\n}\n\n.day{\npadding:8px;\ntext-align:center;\nborder-radius:6px;\ncursor:pointer;\n}\n\n.day:hover{\nbackground:#e6ecff;\n}\n\n.day.selected{\nbackground:#003a8f;\ncolor:white;\n}\n\n.times{\ndisplay:grid;\ngrid-template-columns: repeat(2,1fr);\ngap:8px;\nmargin-top:10px;\n}\n\n.time{\nborder:1px solid #ddd;\npadding:8px;\ntext-align:center;\nborder-radius:6px;\ncursor:pointer;\n}\n\n.time.selected{\nbackground:#ff6a00;\ncolor:white;\nborder:none;\n}\n\nbutton{\nmargin-top:18px;\nwidth:100%;\npadding:12px;\nborder:none;\nborder-radius:8px;\nbackground:#ff6a00;\ncolor:white;\nfont-size:16px;\ncursor:pointer;\n}\n\n</style>\n\n</head>\n\n<body>\n\n<div class=\"container\">\n\n<div class=\"header\">\nAgendar atendimento\n</div>\n\n<div id=\"calendar\" class=\"calendar\"></div>\n\n<div id=\"times\" class=\"times\"></div>\n\n<button onclick=\"confirmar()\">Confirmar agendamento</button>\n\n</div>\n\n<script>\n\nconst calendar = document.getElementById(\"calendar\")\nconst timesDiv = document.getElementById(\"times\")\n\nlet selectedDate = null\nlet selectedTime = null\n\nconst horarios = [\n\"09:00\",\"10:00\",\"11:00\",\n\"13:00\",\"14:00\",\"15:00\",\n\"16:00\",\"17:00\"\n]\n\n// gera próximos 10 dias\nfunction gerarCalendario(){\n\nconst hoje = new Date()\n\nfor(let i=1;i<=10;i++){\n\nconst data = new Date()\ndata.setDate(hoje.getDate()+i)\n\nconst el = document.createElement(\"div\")\nel.className=\"day\"\n\nconst dia = data.getDate()\nconst mes = data.getMonth()+1\n\nel.innerText = `${dia}/${mes}`\n\nel.onclick = ()=>{\n\ndocument.querySelectorAll(\".day\").forEach(d=>d.classList.remove(\"selected\"))\nel.classList.add(\"selected\")\n\nselectedDate = data.toISOString().split(\"T\")[0]\n\nmostrarHorarios()\n\n}\n\ncalendar.appendChild(el)\n\n}\n\n}\n\nfunction mostrarHorarios(){\n\ntimesDiv.innerHTML=\"\"\n\nhorarios.forEach(h=>{\n\nconst el = document.createElement(\"div\")\nel.className=\"time\"\nel.innerText = h\n\nel.onclick = ()=>{\n\ndocument.querySelectorAll(\".time\").forEach(t=>t.classList.remove(\"selected\"))\nel.classList.add(\"selected\")\n\nselectedTime = h\n\n}\n\ntimesDiv.appendChild(el)\n\n})\n\n}\n\nfunction confirmar(){\n\nif(!selectedDate || !selectedTime){\n\nalert(\"Selecione data e horário\")\nreturn\n\n}\n\nconst mensagem = JSON.stringify({\ndataAgendamento:selectedDate,\nhoraAgendamento:selectedTime\n})\n\n// envia para o Cognigy como mensagem do usuário\nwindow.parent.postMessage(\n{\ntype:\"webchat:send\",\npayload:mensagem\n},\n\"*\"\n)\n\n// fecha a janela do xApp\nsetTimeout(()=>{\n\nwindow.close()\n\n},300)\n\n}\n\ngerarCalendario()\n\n</script>\n\n</body>\n</html>","waitForInput":false,"storeResultInContext":false,"contextKey":"dataAgendamento","screenTitle":"","showCloseIcon":true,"sendEventOnCloseIconClick":false,"autoOpen":true,"closeOnSubmit":true,"feedbackMessage":""},"preview":"","localeReference":"69f8abdb1d175af3ed2a8d25"}],"chartReference":"69f8abdb1d175af3ed2a8d29","resourceReference":"69f8abdb1d175af3ed2a8d28","projectReference":"69f8abdb1d175af3ed2a8cc7","organisationReference":"68bdfe9b0d262300236aafc7"}