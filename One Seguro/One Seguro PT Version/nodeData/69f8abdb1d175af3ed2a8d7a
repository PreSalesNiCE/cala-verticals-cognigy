{"_id":"69f8abdb1d175af3ed2a8d7a","referenceId":"83b34daf-7aa9-44c4-8bc6-cc06021cadef","type":"setHTMLAppState","extension":"@cognigy/basic-nodes","label":"Tipo de Sinistro","comment":"","commentColor":"","analyticsLabel":null,"isEntryPoint":true,"isDisabled":false,"mock":{"isEnabled":false,"code":""},"localizedData":[{"config":{"mode":"full","html":"<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>One Seguros - Registrar Sinistro</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          colors: {\n            onePrimary: '#1E3A8A',\n            onePrimaryLight: '#E5F0FF',\n            oneDark: '#111827',\n            oneLight: '#F9FAFB',\n            oneGold: '#D4AF37'\n          }\n        }\n      }\n    }\n  </script>\n  <script src=\"/sdk/app-page-sdk.js\"></script>\n</head>\n<body class=\"min-h-screen bg-oneLight text-oneDark\">\n  <div class=\"max-w-3xl mx-auto px-4 py-6\">\n    <!-- Header -->\n    <header class=\"flex items-center justify-between mb-6\">\n      <div class=\"flex items-center gap-2\">\n        <div class=\"w-9 h-9 rounded-full bg-onePrimary flex items-center justify-center\">\n          <span class=\"text-white text-sm font-semibold\">1S</span>\n        </div>\n        <div>\n          <h1 class=\"text-lg font-semibold text-oneDark\">One Seguros</h1>\n          <p class=\"text-xs text-slate-500\">Sinistro de veículo</p>\n        </div>\n      </div>\n      <span class=\"px-3 py-1 rounded-full text-xs font-medium bg-onePrimaryLight text-onePrimary border border-onePrimary/10\">\n        Atendimento 24h\n      </span>\n    </header>\n\n    <!-- Card principal -->\n    <main class=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-5 space-y-5\">\n      <!-- Resumo da apólice (mock; você pode preencher via CognigyScript) -->\n      <section class=\"bg-onePrimaryLight/70 rounded-xl p-4 flex flex-col gap-1\">\n        <p class=\"text-xs uppercase tracking-wide text-onePrimary font-semibold\">Sua apólice</p>\n        <p class=\"text-sm text-oneDark font-medium\">\n          Veículo: {{context.cliente.veiculo}}\n        </p>\n        <p class=\"text-xs text-slate-600\">\n          Placa: {{context.cliente.placa}} • Apólice: {{ci.data.policyNumber || \"1234.5678.90\"}}\n        </p>\n        <p class=\"text-xs text-slate-500\">\n          Vigência: {{ci.data.policyValidity || \"01/01/2026 a 31/12/2026\"}}\n        </p>\n      </section>\n\n      <!-- Título e descrição -->\n      <section class=\"space-y-1\">\n        <h2 class=\"text-xl font-semibold text-oneDark\">\n          Vamos registrar seu sinistro\n        </h2>\n        <p class=\"text-sm text-slate-600\">\n          Leva menos de <span class=\"font-semibold\">5 minutos</span>. Você pode pausar e continuar depois.\n        </p>\n      </section>\n\n      <!-- Barra de progresso (passo 1 de 6) -->\n      <section>\n        <div class=\"flex items-center justify-between text-xs mb-1\">\n          <span class=\"font-medium text-oneDark\">Passo 1 de 6</span>\n          <span class=\"text-slate-500\">Tipo de sinistro</span>\n        </div>\n        <div class=\"w-full bg-slate-100 rounded-full h-1.5 overflow-hidden\">\n          <div class=\"h-1.5 w-1/6 bg-gradient-to-r from-oneGold to-onePrimary rounded-full\"></div>\n        </div>\n      </section>\n\n      <!-- Tipos de sinistro -->\n      <section class=\"space-y-3\">\n        <p class=\"text-sm font-medium text-oneDark\">\n          Que tipo de sinistro você quer registrar?\n        </p>\n\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n          <!-- Cada card chama SDK.submit com type selecionado -->\n          <button\n            type=\"button\"\n            onclick=\"handleSelectType('Colisão')\"\n            class=\"group text-left bg-oneLight hover:bg-onePrimaryLight transition rounded-xl border border-slate-200 hover:border-onePrimary shadow-sm px-4 py-3 flex flex-col gap-1\"\n          >\n            <div class=\"flex items-center justify-between\">\n              <span class=\"text-sm font-semibold text-oneDark\">Colisão / batida</span>\n              <span class=\"w-7 h-7 rounded-full bg-onePrimary/10 flex items-center justify-center text-xs text-onePrimary\">\n                🚗\n              </span>\n            </div>\n            <p class=\"text-xs text-slate-600\">\n              Batida com outro veículo, muro, poste ou objeto na pista.\n            </p>\n          </button>\n\n          <button\n            type=\"button\"\n            onclick=\"handleSelectType('Roubo ou Furto')\"\n            class=\"group text-left bg-oneLight hover:bg-onePrimaryLight transition rounded-xl border border-slate-200 hover:border-onePrimary shadow-sm px-4 py-3 flex flex-col gap-1\"\n          >\n            <div class=\"flex items-center justify-between\">\n              <span class=\"text-sm font-semibold text-oneDark\">Roubo ou furto</span>\n              <span class=\"w-7 h-7 rounded-full bg-onePrimary/10 flex items-center justify-center text-xs text-onePrimary\">\n                🔒\n              </span>\n            </div>\n            <p class=\"text-xs text-slate-600\">\n              Veículo levado, arrombado ou desaparecido, inclusive tentativa.\n            </p>\n          </button>\n\n          <button\n            type=\"button\"\n            onclick=\"handleSelectType('Danos a terceiros')\"\n            class=\"group text-left bg-oneLight hover:bg-onePrimaryLight transition rounded-xl border border-slate-200 hover:border-onePrimary shadow-sm px-4 py-3 flex flex-col gap-1\"\n          >\n            <div class=\"flex items-center justify-between\">\n              <span class=\"text-sm font-semibold text-oneDark\">Danos a terceiros</span>\n              <span class=\"w-7 h-7 rounded-full bg-onePrimary/10 flex items-center justify-center text-xs text-onePrimary\">\n                🧍\n              </span>\n            </div>\n            <p class=\"text-xs text-slate-600\">\n              Você causou dano a outro veículo ou propriedade.\n            </p>\n          </button>\n\n          <button\n            type=\"button\"\n            onclick=\"handleSelectType('Quebra de vídros, faróis e retrovisores')\"\n            class=\"group text-left bg-oneLight hover:bg-onePrimaryLight transition rounded-xl border border-slate-200 hover:border-onePrimary shadow-sm px-4 py-3 flex flex-col gap-1\"\n          >\n            <div class=\"flex items-center justify-between\">\n              <span class=\"text-sm font-semibold text-oneDark\">Vidros, faróis e retrovisores</span>\n              <span class=\"w-7 h-7 rounded-full bg-onePrimary/10 flex items-center justify-center text-xs text-onePrimary\">\n                🪟\n              </span>\n            </div>\n            <p class=\"text-xs text-slate-600\">\n              Quebra de para‑brisa, vidro lateral/traseiro, faróis ou retrovisores.\n            </p>\n          </button>\n\n          <button\n            type=\"button\"\n            onclick=\"handleSelectType('Fenomenos da natureza')\"\n            class=\"group text-left bg-oneLight hover:bg-onePrimaryLight transition rounded-xl border border-slate-200 hover:border-onePrimary shadow-sm px-4 py-3 flex flex-col gap-1\"\n          >\n            <div class=\"flex items-center justify-between\">\n              <span class=\"text-sm font-semibold text-oneDark\">Fenômenos da natureza</span>\n              <span class=\"w-7 h-7 rounded-full bg-onePrimary/10 flex items-center justify-center text-xs text-onePrimary\">\n                🌧️\n              </span>\n            </div>\n            <p class=\"text-xs text-slate-600\">\n              Enchente, granizo, queda de árvore ou vento forte.\n            </p>\n          </button>\n\n          <button\n            type=\"button\"\n            onclick=\"handleSelectType('Guincho ou assistência')\"\n            class=\"group text-left bg-oneLight hover:bg-onePrimaryLight transition rounded-xl border border-slate-200 hover:border-onePrimary shadow-sm px-4 py-3 flex flex-col gap-1\"\n          >\n            <div class=\"flex items-center justify-between\">\n              <span class=\"text-sm font-semibold text-oneDark\">Guincho / assistência 24h</span>\n              <span class=\"w-7 h-7 rounded-full bg-onePrimary/10 flex items-center justify-center text-xs text-onePrimary\">\n                🛠️\n              </span>\n            </div>\n            <p class=\"text-xs text-slate-600\">\n              Veículo imobilizado, pane mecânica ou pane seca.\n            </p>\n          </button>\n        </div>\n      </section>\n\n      <!-- Ajuda -->\n      <section class=\"pt-2 border-t border-slate-100 flex items-center justify-between text-xs text-slate-500\">\n        <p>Dúvidas? Fale com um especialista One Seguros.</p>\n        <a href=\"https://wa.me/SEU_NUMERO\" class=\"text-onePrimary font-medium hover:underline\">\n          Abrir WhatsApp\n        </a>\n      </section>\n    </main>\n  </div>\n\n  <script>\n    function handleSelectType(type) {\n      SDK.submit({\n        step: 'tipoSinistroSelecionado',\n        sinistroTipo: type\n      });\n    }\n  </script>\n</body>\n</html>","body":"<!DOCTYPE html>\n<html lang=\"pt-br\">\n<head>\n<meta charset=\"UTF-8\">\n\n<style>\n\nbody{\nfont-family: Arial, sans-serif;\nbackground:#f4f6fb;\ndisplay:flex;\njustify-content:center;\nalign-items:center;\nheight:100vh;\nmargin:0;\n}\n\n.container{\nbackground:white;\nwidth:360px;\nborder-radius:14px;\npadding:20px;\nbox-shadow:0 6px 18px rgba(0,0,0,0.15);\n}\n\n.header{\ncolor:#003a8f;\nfont-size:20px;\nfont-weight:bold;\nmargin-bottom:12px;\n}\n\n.calendar{\ndisplay:grid;\ngrid-template-columns: repeat(7,1fr);\ngap:6px;\nmargin-bottom:14px;\n}\n\n.day{\npadding:8px;\ntext-align:center;\nborder-radius:6px;\ncursor:pointer;\n}\n\n.day:hover{\nbackground:#e6ecff;\n}\n\n.day.selected{\nbackground:#003a8f;\ncolor:white;\n}\n\n.times{\ndisplay:grid;\ngrid-template-columns: repeat(2,1fr);\ngap:8px;\nmargin-top:10px;\n}\n\n.time{\nborder:1px solid #ddd;\npadding:8px;\ntext-align:center;\nborder-radius:6px;\ncursor:pointer;\n}\n\n.time.selected{\nbackground:#ff6a00;\ncolor:white;\nborder:none;\n}\n\nbutton{\nmargin-top:18px;\nwidth:100%;\npadding:12px;\nborder:none;\nborder-radius:8px;\nbackground:#ff6a00;\ncolor:white;\nfont-size:16px;\ncursor:pointer;\n}\n\n</style>\n\n</head>\n\n<body>\n\n<div class=\"container\">\n\n<div class=\"header\">\nAgendar atendimento\n</div>\n\n<div id=\"calendar\" class=\"calendar\"></div>\n\n<div id=\"times\" class=\"times\"></div>\n\n<button onclick=\"confirmar()\">Confirmar agendamento</button>\n\n</div>\n\n<script>\n\nconst calendar = document.getElementById(\"calendar\")\nconst timesDiv = document.getElementById(\"times\")\n\nlet selectedDate = null\nlet selectedTime = null\n\nconst horarios = [\n\"09:00\",\"10:00\",\"11:00\",\n\"13:00\",\"14:00\",\"15:00\",\n\"16:00\",\"17:00\"\n]\n\n// gera próximos 10 dias\nfunction gerarCalendario(){\n\nconst hoje = new Date()\n\nfor(let i=1;i<=10;i++){\n\nconst data = new Date()\ndata.setDate(hoje.getDate()+i)\n\nconst el = document.createElement(\"div\")\nel.className=\"day\"\n\nconst dia = data.getDate()\nconst mes = data.getMonth()+1\n\nel.innerText = `${dia}/${mes}`\n\nel.onclick = ()=>{\n\ndocument.querySelectorAll(\".day\").forEach(d=>d.classList.remove(\"selected\"))\nel.classList.add(\"selected\")\n\nselectedDate = data.toISOString().split(\"T\")[0]\n\nmostrarHorarios()\n\n}\n\ncalendar.appendChild(el)\n\n}\n\n}\n\nfunction mostrarHorarios(){\n\ntimesDiv.innerHTML=\"\"\n\nhorarios.forEach(h=>{\n\nconst el = document.createElement(\"div\")\nel.className=\"time\"\nel.innerText = h\n\nel.onclick = ()=>{\n\ndocument.querySelectorAll(\".time\").forEach(t=>t.classList.remove(\"selected\"))\nel.classList.add(\"selected\")\n\nselectedTime = h\n\n}\n\ntimesDiv.appendChild(el)\n\n})\n\n}\n\nfunction confirmar(){\n\nif(!selectedDate || !selectedTime){\n\nalert(\"Selecione data e horário\")\nreturn\n\n}\n\nconst mensagem = JSON.stringify({\ndataAgendamento:selectedDate,\nhoraAgendamento:selectedTime\n})\n\n// envia para o Cognigy como mensagem do usuário\nwindow.parent.postMessage(\n{\ntype:\"webchat:send\",\npayload:mensagem\n},\n\"*\"\n)\n\n// fecha a janela do xApp\nsetTimeout(()=>{\n\nwindow.close()\n\n},300)\n\n}\n\ngerarCalendario()\n\n</script>\n\n</body>\n</html>","waitForInput":false,"storeResultInContext":false,"contextKey":"dataAgendamento","screenTitle":"","showCloseIcon":true,"sendEventOnCloseIconClick":false,"autoOpen":true,"closeOnSubmit":true,"feedbackMessage":""},"preview":"","localeReference":"69f8abdb1d175af3ed2a8d25"}],"chartReference":"69f8abdb1d175af3ed2a8d29","resourceReference":"69f8abdb1d175af3ed2a8d28","projectReference":"69f8abdb1d175af3ed2a8cc7","organisationReference":"68bdfe9b0d262300236aafc7"}