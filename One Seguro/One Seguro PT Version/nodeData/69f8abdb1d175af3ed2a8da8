{"_id":"69f8abdb1d175af3ed2a8da8","referenceId":"ac319270-85f2-4fca-aa29-39c4be707805","type":"setHTMLAppState","label":"Fotos Sinistro","comment":"","commentColor":"","analyticsLabel":null,"isDisabled":false,"isEntryPoint":true,"localizedData":[{"config":{"mode":"full","html":"<!DOCTYPE html>\n<html lang=\"pt-BR\">\n\n<head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>One Seguros - Fotos e Documentos</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script>\n        tailwind.config = {\n            theme: {\n                extend: {\n                    colors: {\n                        onePrimary: '#1E3A8A',\n                        onePrimaryLight: '#E5F0FF',\n                        oneDark: '#111827',\n                        oneLight: '#F9FAFB',\n                        oneGold: '#D4AF37'\n                    }\n                }\n            }\n        }\n    </script>\n    <script src=\"/sdk/app-page-sdk.js\"></script>\n</head>\n\n<body class=\"min-h-screen bg-oneLight text-oneDark\">\n    <div class=\"max-w-3xl mx-auto px-4 py-6\">\n        <header class=\"flex items-center justify-between mb-4\">\n            <div class=\"flex items-center gap-2\">\n                <button type=\"button\" onclick=\"handleBack()\"\n                    class=\"mr-2 inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs text-slate-600 hover:border-onePrimary hover:text-onePrimary hover:bg-onePrimaryLight transition\">\n                    ← Voltar\n                </button>\n                <div class=\"flex items-center gap-2\">\n                    <div class=\"w-9 h-9 rounded-full bg-onePrimary flex items-center justify-center\">\n                        <span class=\"text-white text-sm font-semibold\">1S</span>\n                    </div>\n                    <div>\n                        <h1 class=\"text-lg font-semibold text-oneDark\">Detalhes do evento</h1>\n                        <p class=\"text-xs text-slate-500\">Conte rapidamente o que aconteceu.</p>\n                    </div>\n                </div>\n            </div>\n            <span class=\"text-xs text-slate-500\">Passo 2 de 6</span>\n        </header>\n\n        <main class=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-5 space-y-5\">\n            <!-- Progresso -->\n            <section>\n                <div class=\"flex items-center justify-between text-xs mb-1\">\n                    <span class=\"font-medium text-oneDark\">Progresso</span>\n                    <span class=\"text-slate-500\">Fotos e documentos</span>\n                </div>\n                <div class=\"w-full bg-slate-100 rounded-full h-1.5 overflow-hidden\">\n                    <div class=\"h-1.5 w-5/6 bg-gradient-to-r from-oneGold to-onePrimary rounded-full\"></div>\n                </div>\n            </section>\n\n            <form id=\"filesForm\" class=\"space-y-4\" onsubmit=\"handleSubmit(event)\">\n                <!-- Fotos do veículo -->\n                <div class=\"space-y-2\">\n                    <div class=\"flex items-center justify-between\">\n                        <div>\n                            <p class=\"text-sm font-medium text-oneDark\">Fotos do veículo</p>\n                            <p class=\"text-xs text-slate-500\">\n                                Se possível, tire fotos da frente, traseira, lados e detalhes do dano.\n                            </p>\n                        </div>\n                    </div>\n                    <input type=\"file\" id=\"vehiclePhotos\" accept=\"image/*\" multiple\n                        class=\"block w-full text-xs text-slate-500 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-onePrimaryLight file:text-onePrimary hover:file:bg-onePrimary hover:file:text-white\" />\n                </div>\n\n                <!-- Documentos -->\n                <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                    <div>\n                        <p class=\"text-sm font-medium text-oneDark\">Boletim de ocorrência (BO)</p>\n                        <p class=\"text-xs text-slate-500 mb-2\">\n                            Caso já tenha o BO, envie uma foto ou PDF. Se não, você pode anexar depois.\n                        </p>\n                        <input type=\"file\" id=\"boFile\" accept=\"image/*,application/pdf\"\n                            class=\"block w-full text-xs text-slate-500 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-onePrimaryLight file:text-onePrimary hover:file:bg-onePrimary hover:file:text-white\" />\n                    </div>\n\n                    <div>\n                        <p class=\"text-sm font-medium text-oneDark\">Documentos do veículo / condutor</p>\n                        <p class=\"text-xs text-slate-500 mb-2\">\n                            CNH do condutor, documento do veículo (CRLV), etc. Opcional agora.\n                        </p>\n                        <input type=\"file\" id=\"docsFile\" accept=\"image/*,application/pdf\" multiple\n                            class=\"block w-full text-xs text-slate-500 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-onePrimaryLight file:text-onePrimary hover:file:bg-onePrimary hover:file:text-white\" />\n                    </div>\n                </div>\n\n                <p class=\"text-xs text-slate-500\">\n                    Você receberá um link e contatos da One Seguros para enviar mais fotos e documentos depois, se\n                    preferir.\n                </p>\n\n                <!-- Rodapé -->\n                <div class=\"pt-3 border-t border-slate-100 flex items-center justify-between\">\n                    <p class=\"text-xs text-slate-500\">\n                        Próximo passo: revisar informações e enviar o sinistro para análise.\n                    </p>\n                    <button type=\"submit\"\n                        class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-oneGold to-onePrimary text-white text-sm font-medium shadow-sm hover:opacity-95 transition\">\n                        Continuar\n                        <span>→</span>\n                    </button>\n                </div>\n            </form>\n        </main>\n    </div>\n\n    <script>\n        function handleBack() {\n            SDK.submit({\n                step: 'voltar',\n                toPage: 'envolvidos' // personalize para cada página\n            });\n        }\n        function handleSubmit(event) {\n            event.preventDefault();\n\n            // Não enviamos binários via SDK.submit; só meta-dados (qtd. arquivos, tipos)\n            const vehiclePhotos = document.getElementById('vehiclePhotos').files;\n            const boFile = document.getElementById('boFile').files;\n            const docsFile = document.getElementById('docsFile').files;\n\n            const payload = {\n                step: 'fotosDocumentosMeta',\n                vehiclePhotosCount: vehiclePhotos.length,\n                boFileCount: boFile.length,\n                docsFileCount: docsFile.length,\n                // você pode combinar com um upload real via endpoint próprio fora do SDK\n            };\n\n            SDK.submit(payload);\n        }\n    </script>\n</body>\n\n</html>","body":"<form>\n\t<input \n\t\tname=\"nickname\" \n\t\tplaceholder=\"your nickname\"\n\t/> \n\t<button>submit</button>\n</form>\n","waitForInput":false,"storeResultInContext":"","contextKey":"result","screenTitle":"","showCloseIcon":true,"sendEventOnCloseIconClick":false,"autoOpen":true,"closeOnSubmit":true,"feedbackMessage":""},"preview":"","localeReference":"69f8abdb1d175af3ed2a8d25"}],"chartReference":"69f8abdb1d175af3ed2a8d29","extension":"@cognigy/basic-nodes","resourceReference":"69f8abdb1d175af3ed2a8d28","projectReference":"69f8abdb1d175af3ed2a8cc7","organisationReference":"68bdfe9b0d262300236aafc7","mock":{"isEnabled":false,"code":""}}