{"_id":"69f8abdb1d175af3ed2a8d9b","referenceId":"4c9904e0-c39b-4330-bc8a-0b9b227a540c","type":"setHTMLAppState","label":"Envolvidos/Terceiros Sinistro","comment":"","commentColor":"","analyticsLabel":null,"isDisabled":false,"isEntryPoint":true,"localizedData":[{"config":{"mode":"full","html":"<!DOCTYPE html>\n<html lang=\"pt-BR\">\n\n<head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>One Seguros - Envolvidos</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script>\n        tailwind.config = {\n            theme: {\n                extend: {\n                    colors: {\n                        onePrimary: '#1E3A8A',\n                        onePrimaryLight: '#E5F0FF',\n                        oneDark: '#111827',\n                        oneLight: '#F9FAFB',\n                        oneGold: '#D4AF37'\n                    }\n                }\n            }\n        }\n    </script>\n    <script src=\"/sdk/app-page-sdk.js\"></script>\n</head>\n\n<body class=\"min-h-screen bg-oneLight text-oneDark\">\n    <div class=\"max-w-3xl mx-auto px-4 py-6\">\n        <header class=\"flex items-center justify-between mb-4\">\n            <div class=\"flex items-center gap-2\">\n                <button type=\"button\" onclick=\"handleBack()\"\n                    class=\"mr-2 inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs text-slate-600 hover:border-onePrimary hover:text-onePrimary hover:bg-onePrimaryLight transition\">\n                    ← Voltar\n                </button>\n                <div class=\"flex items-center gap-2\">\n                    <div class=\"w-9 h-9 rounded-full bg-onePrimary flex items-center justify-center\">\n                        <span class=\"text-white text-sm font-semibold\">1S</span>\n                    </div>\n                    <div>\n                        <h1 class=\"text-lg font-semibold text-oneDark\">Detalhes do evento</h1>\n                        <p class=\"text-xs text-slate-500\">Conte rapidamente o que aconteceu.</p>\n                    </div>\n                </div>\n            </div>\n            <span class=\"text-xs text-slate-500\">Passo 2 de 6</span>\n        </header>\n\n        <main class=\"bg-white rounded-2xl shadow-sm border border-slate-100 p-5 space-y-5\">\n            <!-- Progresso -->\n            <section>\n                <div class=\"flex items-center justify-between text-xs mb-1\">\n                    <span class=\"font-medium text-oneDark\">Progresso</span>\n                    <span class=\"text-slate-500\">Envolvidos</span>\n                </div>\n                <div class=\"w-full bg-slate-100 rounded-full h-1.5 overflow-hidden\">\n                    <div class=\"h-1.5 w-4/6 bg-gradient-to-r from-oneGold to-onePrimary rounded-full\"></div>\n                </div>\n            </section>\n\n            <form id=\"envolvidosForm\" class=\"space-y-4\" onsubmit=\"handleSubmit(event)\">\n                <!-- Veículos envolvidos -->\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-2\">\n                        Existiram outros veículos envolvidos?\n                    </label>\n                    <div class=\"flex flex-wrap gap-2 text-sm\">\n                        <button type=\"button\"\n                            class=\"vehicles-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            data-value=\"nao\" onclick=\"selectVehicles(this)\">\n                            Não\n                        </button>\n                        <button type=\"button\"\n                            class=\"vehicles-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            data-value=\"1\" onclick=\"selectVehicles(this)\">\n                            Sim, 1 veículo\n                        </button>\n                        <button type=\"button\"\n                            class=\"vehicles-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            data-value=\"mais_1\" onclick=\"selectVehicles(this)\">\n                            Sim, mais de 1\n                        </button>\n                    </div>\n                    <input type=\"hidden\" id=\"vehiclesInvolved\" required />\n                </div>\n\n                <!-- Danos a terceiros -->\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-2\">\n                        Houve danos a terceiros (muro, portão, fachada, poste, etc.)?\n                    </label>\n                    <div class=\"flex flex-wrap gap-2 text-sm\">\n                        <button type=\"button\"\n                            class=\"third-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            data-value=\"nao\" onclick=\"selectThirdDamage(this)\">\n                            Não\n                        </button>\n                        <button type=\"button\"\n                            class=\"third-btn rounded-lg border border-slate-200 bg-oneLight px-3 py-2 hover:border-onePrimary hover:bg-onePrimaryLight\"\n                            data-value=\"materiais\" onclick=\"selectThirdDamage(this)\">\n                            Sim, danos materiais\n                        </button>\n                    </div>\n                    <input type=\"hidden\" id=\"thirdDamage\" required />\n                </div>\n\n                <!-- Contato de terceiros (opcional) -->\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-1\">\n                        Nome do principal terceiro (opcional)\n                    </label>\n                    <input type=\"text\" id=\"thirdName\" placeholder=\"Ex.: João da Silva\"\n                        class=\"w-full rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-onePrimary focus:border-onePrimary\" />\n                </div>\n\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-1\">\n                        Contato do terceiro (telefone ou e-mail) – opcional\n                    </label>\n                    <input type=\"text\" id=\"thirdContact\" placeholder=\"Ex.: (11) 99999-0000 ou joao@email.com\"\n                        class=\"w-full rounded-lg border border-slate-200 bg-oneLight px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-onePrimary focus:border-onePrimary\" />\n                    <p class=\"mt-1 text-xs text-slate-500\">\n                        Esses dados ajudam nossa equipe a agilizar o contato, mas você pode informar depois.\n                    </p>\n                </div>\n\n                <!-- Autoridades -->\n                <div>\n                    <label class=\"block text-xs font-medium text-slate-600 mb-2\">\n                        Houve envolvimento de autoridades no local?\n                    </label>\n                    <div class=\"flex flex-wrap gap-2 text-sm\">\n                        <label class=\"inline-flex items-center gap-2\">\n                            <input type=\"checkbox\" id=\"police\"\n                                class=\"rounded border-slate-300 text-onePrimary focus:ring-onePrimary\" />\n                            <span>Polícia</span>\n                        </label>\n                        <label class=\"inline-flex items-center gap-2\">\n                            <input type=\"checkbox\" id=\"cityGuard\"\n                                class=\"rounded border-slate-300 text-onePrimary focus:ring-onePrimary\" />\n                            <span>Guarda Municipal</span>\n                        </label>\n                        <label class=\"inline-flex items-center gap-2\">\n                            <input type=\"checkbox\" id=\"noAuthorities\"\n                                class=\"rounded border-slate-300 text-onePrimary focus:ring-onePrimary\" />\n                            <span>Nenhuma autoridade</span>\n                        </label>\n                    </div>\n                </div>\n\n                <!-- Rodapé -->\n                <div class=\"pt-3 border-t border-slate-100 flex items-center justify-between\">\n                    <p class=\"text-xs text-slate-500\">\n                        Se faltar alguma informação, nossa equipe entra em contato com você depois.\n                    </p>\n                    <button type=\"submit\"\n                        class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-oneGold to-onePrimary text-white text-sm font-medium shadow-sm hover:opacity-95 transition\">\n                        Continuar\n                        <span>→</span>\n                    </button>\n                </div>\n            </form>\n        </main>\n    </div>\n\n    <script>\n        function handleBack() {\n            SDK.submit({\n                step: 'voltar',\n                toPage: 'local' // personalize para cada página\n            });\n        }\n\n        function selectVehicles(btn) {\n            document.querySelectorAll('.vehicles-btn').forEach(b => {\n                b.classList.remove('border-onePrimary', 'bg-onePrimaryLight');\n            });\n            btn.classList.add('border-onePrimary', 'bg-onePrimaryLight');\n            document.getElementById('vehiclesInvolved').value = btn.dataset.value;\n        }\n\n        function selectThirdDamage(btn) {\n            document.querySelectorAll('.third-btn').forEach(b => {\n                b.classList.remove('border-onePrimary', 'bg-onePrimaryLight');\n            });\n            btn.classList.add('border-onePrimary', 'bg-onePrimaryLight');\n            document.getElementById('thirdDamage').value = btn.dataset.value;\n        }\n\n        function handleSubmit(event) {\n            event.preventDefault();\n\n            const authorities = [];\n            if (document.getElementById('police').checked) authorities.push('policia');\n            if (document.getElementById('cityGuard').checked) authorities.push('guarda_municipal');\n            if (document.getElementById('noAuthorities').checked || authorities.length === 0) {\n                if (authorities.length === 0) {\n                    authorities.push('nenhuma');\n                }\n            }\n\n            const payload = {\n                step: 'envolvidosTerceiros',\n                vehiclesInvolved: document.getElementById('vehiclesInvolved').value,\n                thirdDamage: document.getElementById('thirdDamage').value,\n                thirdName: document.getElementById('thirdName').value || null,\n                thirdContact: document.getElementById('thirdContact').value || null,\n                authorities\n            };\n\n            SDK.submit(payload);\n        }\n    </script>\n</body>\n\n</html>","body":"<form>\n\t<input \n\t\tname=\"nickname\" \n\t\tplaceholder=\"your nickname\"\n\t/> \n\t<button>submit</button>\n</form>\n","waitForInput":false,"storeResultInContext":"","contextKey":"result","screenTitle":"","showCloseIcon":true,"sendEventOnCloseIconClick":false,"autoOpen":true,"closeOnSubmit":true,"feedbackMessage":""},"preview":"","localeReference":"69f8abdb1d175af3ed2a8d25"}],"mock":{"isEnabled":false,"code":""},"chartReference":"69f8abdb1d175af3ed2a8d29","extension":"@cognigy/basic-nodes","resourceReference":"69f8abdb1d175af3ed2a8d28","projectReference":"69f8abdb1d175af3ed2a8cc7","organisationReference":"68bdfe9b0d262300236aafc7"}